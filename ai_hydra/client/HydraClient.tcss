/* RNN Model is Selected */
/* --------------------- */
.rnn #batch_size_input {
    display: none;
}
.rnn #batch_size_label {
    display: none;
}

/* GRU Model is Seleted */
/* -------------------- */
.gru #batch_size_input {
    display: none;
}
.gru #batch_size_label {
    display: none;
}

/* Linear Model is Selected */
/* ------------------------ */
.linear #batch_size_input {
    display: none;
}
.linear #batch_size_label {
    display: none;
}


/* Turbo mode is ON */
.turbo_on #move_delay_input {
    display: none;
}
.turbo_on #board {
    display: none;
}

/* Turbo mode is OFF */
.turbo_off #move_delay_label {
    display: none;
}
