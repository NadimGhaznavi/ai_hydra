Screen {
    layout: grid;
    grid-size: 4 9;
    grid-rows: 3 14 3 3 2 1 22 3;
    grid-columns: 20 45 44 37;
}

/* Individual widget styling */
Button {
    background: #082641;
    padding: 0 1;
    border: none;
}
Switch {
    border: none;
    padding: 0;
}


/* Grid boxes */
#title {
    column-span: 4;
    background: black;
    border: round #2aa5ce;
    border-subtitle-color: #5fc442;
    color: #5fc442;
    text-style: bold;
    width: 100%;
    padding: 0 1;
}
#buttons {
    background: black;
    height: 14;
    border: round #2aa5ce;
    border-subtitle-color: #42bbc4;
    border-subtitle-style: bold;
    color: #5fc442;
    text-style: bold;
    padding: 0 1;
}
#board_box {
    row-span: 4;
    height: 22;
    background: black;
    border: round #2aa5ce;
    border-subtitle-color: #42bbc4;
    border-subtitle-style: bold;
    border-title-color: #42bbc4;
    border-title-style: bold;
    color: #5fc442;
    text-style: bold;
    padding: 0 1;
}
#tabbed_settings {
    row-span: 5;
    background: black;
    border: round #2aa5ce;
    border-title-color: #42bbc4;
    text-style: bold;
    border-title-style: bold;
    color: #72af75;
    width: 100%;
    padding: 0 1;
}
HighScoresLog {
    row-span: 5;
    background: black;
    border: round #2aa5ce;
    border-subtitle-color: #42bbc4;
    border-subtitle-style: bold;
}
#random_seed_box {
    background: black;
    border: round #2aa5ce;
    border-subtitle-color: #42bbc4;
    border-subtitle-style: bold;
    padding: 0 2;
}
#move_delay_box {
    background: black;
    border: round #2aa5ce;
    border-subtitle-color: #42bbc4;
    border-subtitle-style: bold;
    padding: 0 2;
}
#turbo_box {
    height: 3;
    row-span: 2;
    background: black;
    border: round #2aa5ce;
    border-subtitle-color: #42bbc4;
    border-subtitle-style: bold;
    text-style: bold;
    padding: 0 0;
    align: center middle;
    color: #72af75;    
}
#blank {
    background: black;
}

#both {
    background: black;
}

#both {
    background: black;
}

/* Tabbed Setting boxes */
#epsilon_box {
    background: black;
    border: round #2aa5ce;
    border-subtitle-color: #42bbc4;
    border-subtitle-style: bold;
    text-style: bold;
    color: #72af75;
}
#model_box {
    background: black;
    border: round #2aa5ce;
    border-subtitle-color: #42bbc4;
    border-subtitle-style: bold;
    color: #72af75;
    text-style: bold;
}
#training_box {
    background: black;
    border: round #2aa5ce;
    border-subtitle-color: #42bbc4;
    border-subtitle-style: bold;
    color: #72af75;
    text-style: bold;
}
#router_box {
    background: black;
    border: round #2aa5ce;
    border-subtitle-color: #42bbc4;
    border-subtitle-style: bold;
    color: #72af75;
    text-style: bold;
    height: 6;
}
#server_box {
    background: black;
    border: round #2aa5ce;
    border-subtitle-color: #42bbc4;
    border-subtitle-style: bold;
    color: #72af75;
    text-style: bold;
    height: 5;
}
#mem_sizing_box {
    background: black;
    border: round #2aa5ce;
    border-subtitle-color: #42bbc4;
    border-subtitle-style: bold;
    color: #72af75;
    text-style: bold;
    height: 5;
}
#shifting_box {
    background: black;
    border: round #2aa5ce;
    border-subtitle-color: #42bbc4;
    border-subtitle-style: bold;
    color: #72af75;
    text-style: bold;
    height: 6;
}
#stagnation_box {
    background: black;
    border: round #2aa5ce;
    border-subtitle-color: #42bbc4;
    border-subtitle-style: bold;
    color: #72af75;
    text-style: bold;
    height:4;
}
#nice_box {
    background: black;
    border: round #2aa5ce;
    border-subtitle-color: #42bbc4;
    border-subtitle-style: bold;
    color: #72af75;
    text-style: bold;
    height:4;
}
#mcts_box {
    background: black;
    border: round #2aa5ce;
    border-subtitle-color: #42bbc4;
    border-subtitle-style: bold;
    color: #72af75;
    text-style: bold;
    height: 3;
}
#reward_structure_box {
    background: black;
    border: round #2aa5ce;
    border-subtitle-color: #42bbc4;
    border-subtitle-style: bold;
    color: #72af75;
    text-style: bold;
    height: 5;
}
#movement_incentives_box {
    background: black;
    border: round #2aa5ce;
    border-subtitle-color: #42bbc4;
    border-subtitle-style: bold;
    color: #72af75;
    text-style: bold;
    height: 5;
}
#episode_constraints_box {
    background: black;
    border: round #2aa5ce;
    border-subtitle-color: #42bbc4;
    border-subtitle-style: bold;
    color: #72af75;
    text-style: bold;
    height: 3;
}




/* Widgets that change during a simulation run */
#cur_epsilon {
    color: #cdbf2f;
}
#seq_length_label {
    color: #cdbf2f;
}
#rnn_batch_size_label {
    color: #cdbf2f;
}
#move_delay_label {
    text-style: bold;
    color: #cdbf2f;
}

#highscores {
    background: black;
}

.highscores_box {
    background: black;
}

.input_field {
    height: 1;
    padding: 0 1;
}

/* ---------- ATHReplayMemory --- */
#ath_memory {
    column-span: 4;
    align: center middle;
    width: 100%;
    background: black;
}
#replay_mem {
    border: round #2aa5ceff;
    text-style: bold;
    padding: 0 1;
    color: #54ac59;
    width: 26;
    text-align: center;
}
.bucket {
    border: round #2aa5ceff;
    color: #ffffff;
    text-align: center;
    text-style: bold;
    width: 6;
}

/* ---------- HydraTelemetry --- */
HydraTelemetry {
    column-span: 4;
    background: black;
    border: round #2aa5ceff;
    border-subtitle-color: #c4c242;
    border-title-color: #c4c242;
    text-style: bold;
    padding: 0 1;
    color: #54ac59;
}

/* --- GameScorePlot --- */
GameScorePlot {
    height: 18;
}
#plot_cur_score {
    height: 18;
    width: 90;
}
#plot_highscores {
    height: 18;
    width: 50;
}

/* --- ScoreDistPlot --- */
ScoresDistPlot {
    height: 18;
}
#plot_scores_dist {
    height: 18;
    width: 90;
}
#plot_recent_scores_dist {
    height: 18;
    width: 50;
}

/* --- LossPlot --- */
LossPlot {
    height: 18;
}
#plot_loss {
    height: 18;
    width: 90;
}
#plot_recent_loss {
    height: 18;
    width: 50;
}

/* --- EventLog --- */
EventLog {
    height: 18;
}
#event_log_log {
    background: black;
}

/* -------------------------------------------- */

#settings {
    background: black;
    border: round #2aa5ce;
    border-subtitle-color: #c4c242;
    color: #72af75;
    text-style: bold;
    height: 18;
}

#static_1 {
    height: 100%;
    background: #ff0000;
}

/* Visibity is managed here */
/* -------------------------*/
#hidden_widget {
    display: none;
}

/* Simulation is NOT running */
/* --------------------------*/
.sim_stopped #batch_size_label {
    display: none;
}
.sim_stopped #closer_to_food_label {
    display: none;
}
.sim_stopped #collision_penalty_label {
